{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Tests (Apple-Debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Apple-Debug/tests/asynchrony_tests",
            "args": [],
