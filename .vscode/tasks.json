{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: configure [Apple-Debug]",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "Apple-Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$cmake"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Configure using default Apple Clang compiler from Xcode"
        },
        {
            "label": "cmake: build [Apple-Debug]",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "Apple-Debug",
                "--",
                "-v"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": [
                "cmake: configure [Apple-Debug]"
            ],
            "detail": "Build tests using default Apple Clang compiler from Xcode"
        },
